rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Device tokens — authenticated users only, Cloud Functions read via admin SDK
    match /devices/{deviceId} {
      allow write: if request.auth != null;
      allow read: if false;
    }
    // User-scoped data — only the owning user can read/write
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Root-level collections — read-only for migration, block everything else
    match /checklist/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /spo2/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /meds/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /dailylog/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
