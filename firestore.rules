rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Device tokens — authenticated users only, must include uid
    match /devices/{deviceId} {
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(['token', 'uid'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.token is string
        && request.resource.data.token.size() < 500;
      allow delete: if request.auth != null;
      allow read: if false;
    }
    // User-scoped data — only the owning user can read/write, with schema validation
    match /users/{userId}/{collection}/{docId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && (
          // checklist records
          (collection == 'checklist' && (
            request.resource.data.date is string
            && request.resource.data.date.size() == 10
            && request.resource.data.ts is number
          ))
          // spo2 records
          || (collection == 'spo2' && (
            request.resource.data.date is string
            && request.resource.data.spo2 is number
            && request.resource.data.spo2 >= 70
            && request.resource.data.spo2 <= 100
            && request.resource.data.ts is number
          ))
          // meds records
          || (collection == 'meds' && (
            request.resource.data.date is string
            && request.resource.data.ts is number
          ))
          // dailylog records
          || (collection == 'dailylog' && (
            request.resource.data.date is string
            && request.resource.data.ts is number
          ))
        );
    }
    // Root-level collections — read-only for migration, block everything else
    match /checklist/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /spo2/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /meds/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /dailylog/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
