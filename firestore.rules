rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user personal app — permissive rules
    // The FCM token doc is write-only from client; Cloud Functions read via admin SDK
    match /devices/{deviceId} {
      allow write: if true;
      allow read: if false;
    }
    // App data collections
    match /checklist/{docId} {
      allow read, write: if true;
    }
    match /spo2/{docId} {
      allow read, write: if true;
    }
    match /meds/{docId} {
      allow read, write: if true;
    }
    match /dailylog/{docId} {
      allow read, write: if true;
    }
  }
}
